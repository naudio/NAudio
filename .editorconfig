# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8-bom
indent_style = space
indent_size = 4
insert_final_newline = true

# C# files
[*.cs]
indent_size = 4

# =============================================================================
# C# code style preferences
#
# These document the conventions NAudio actually follows so the IDE steers
# contributors the same way. Severities here are kept light (suggestion);
# the rules that are *enforced* (promoted to warning) are listed in
# .globalconfig. See CLAUDE.md / Docs/Architecture for the rationale.
# =============================================================================

# --- Namespaces ---
# File-scoped namespaces: one less level of indentation, and the modern
# default for new C#. The codebase is converted to this style wholesale.
csharp_style_namespace_declarations = file_scoped:suggestion

# --- 'var' is the house style ---
# NAudio uses 'var' pervasively. Prefer it everywhere so the analyzer steers
# contributors towards the existing style instead of fighting it.
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# --- Primary constructors ---
# NAudio does not use primary constructors: many types are interop/POCO
# shapes where explicit fields and constructors read more clearly. Don't
# nudge contributors towards them.
csharp_style_prefer_primary_constructors = false:suggestion

# --- goto labels ---
# Leave goto-label indentation as written rather than enforcing a style.
# Pinned explicitly because SDK/analyzer versions disagree on the default:
# a label sitting at its surrounding indent passed a local build but failed
# CI under the enforced IDE0055. The codebase has a single label (the ported
# WdlResampler), so 'no_change' keeps it with its code instead of fighting it.
csharp_indent_labels = no_change

# Library source: enforce removal of unnecessary usings. IDE0005 only runs on
# build when GenerateDocumentationFile=true, which the packaged libraries under
# src/ set but the sample/tool projects don't — so it's scoped here rather than
# in the global config (which would error out the samples' build).
[src/**.cs]
dotnet_diagnostic.IDE0005.severity = warning
