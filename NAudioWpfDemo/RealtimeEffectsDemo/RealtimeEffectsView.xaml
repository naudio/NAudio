<UserControl x:Class="NAudioWpfDemo.RealtimeEffectsDemo.RealtimeEffectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:rt="clr-namespace:NAudioWpfDemo.RealtimeEffectsDemo"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="560">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <DataTemplate DataType="{x:Type rt:ParameterViewModel}">
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="90" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" />

                <Slider Grid.Column="1" VerticalAlignment="Center" Margin="4,0"
                        Minimum="{Binding Minimum}" Maximum="{Binding Maximum}"
                        Value="{Binding Value, Mode=TwoWay}"
                        Visibility="{Binding ShowSlider, Converter={StaticResource BoolToVis}}" />
                <CheckBox Grid.Column="1" VerticalAlignment="Center" Margin="4,0"
                          IsChecked="{Binding BoolValue, Mode=TwoWay}"
                          Visibility="{Binding ShowToggle, Converter={StaticResource BoolToVis}}" />
                <ComboBox Grid.Column="1" VerticalAlignment="Center" Margin="4,0"
                          ItemsSource="{Binding Choices}"
                          SelectedIndex="{Binding ChoiceIndex, Mode=TwoWay}"
                          Visibility="{Binding ShowChoice, Converter={StaticResource BoolToVis}}" />
                <ProgressBar Grid.Column="1" Height="14" Margin="4,0"
                             Minimum="{Binding Minimum}" Maximum="{Binding Maximum}"
                             Value="{Binding Value, Mode=OneWay}"
                             Visibility="{Binding ShowMeter, Converter={StaticResource BoolToVis}}" />

                <TextBlock Grid.Column="2" Text="{Binding DisplayValue}"
                           VerticalAlignment="Center" TextAlignment="Right" />
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type rt:EffectSlotViewModel}">
            <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="3"
                    Margin="0,4" Padding="6">
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,4">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Name}"
                                   FontWeight="Bold" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Content="✕" Width="26" Margin="2,0"
                                Command="{Binding RemoveCommand}" ToolTip="Remove" />
                        <Button DockPanel.Dock="Right" Content="▼" Width="26" Margin="2,0"
                                Command="{Binding MoveDownCommand}" ToolTip="Move down" />
                        <Button DockPanel.Dock="Right" Content="▲" Width="26" Margin="2,0"
                                Command="{Binding MoveUpCommand}" ToolTip="Move up" />
                        <CheckBox DockPanel.Dock="Right" Content="Bypass" Margin="8,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding Bypass, Mode=TwoWay}" />
                    </DockPanel>
                    <Grid Margin="0,0,0,4"
                          Visibility="{Binding HasMix, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mix" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="1" Margin="4,0"
                                VerticalAlignment="Center" Value="{Binding Mix, Mode=TwoWay}" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Parameters}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="ASIO driver:" VerticalAlignment="Center" Width="80" />
            <ComboBox Width="200" ItemsSource="{Binding Drivers}"
                      SelectedItem="{Binding SelectedDriver, Mode=TwoWay}" />
            <ComboBox Width="120" Margin="8,0,0,0"
                      SelectedIndex="{Binding InputChannelsIndex, Mode=TwoWay}">
                <ComboBoxItem Content="Mono in" />
                <ComboBoxItem Content="Stereo in" />
            </ComboBox>
            <TextBlock Text="from ch" VerticalAlignment="Center" Margin="8,0,4,0" />
            <TextBox Width="40" VerticalAlignment="Center"
                     Text="{Binding InputChannelOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="First ASIO input channel (1-based). E.g. 2 for a guitar on input 2; 5 for a stereo pair on 5+6." />
            <Button Content="Start" Width="64" Margin="8,0,4,0" Command="{Binding StartCommand}" />
            <Button Content="Stop" Width="64" Command="{Binding StopCommand}" />
        </StackPanel>

        <CheckBox Grid.Row="1" Content="Enable monitoring (pass audio through to output)"
                  IsChecked="{Binding Monitoring, Mode=TwoWay}" />
        <TextBlock Grid.Row="2" Margin="0,2,0,6" TextWrapping="Wrap" Foreground="#B00020"
                   Text="⚠ Use headphones. Monitoring a mic through speakers will feed back. Output starts muted and auto-mutes on a runaway level." />

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="Choose file…" Command="{Binding ChooseInputFileCommand}" />
            <TextBlock Text="{Binding InputFilePath}" VerticalAlignment="Center" Margin="8,0"
                       TextTrimming="CharacterEllipsis" MaxWidth="220" />
            <Button Content="Play" Width="56" Margin="4,0,4,0" Command="{Binding PlayFileCommand}" />
            <Button Content="Stop" Width="56" Margin="0,0,4,0" Command="{Binding StopFileCommand}" />
            <Button Content="Render…" Command="{Binding RenderCommand}" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Add effect:" VerticalAlignment="Center" Width="80" />
            <ComboBox Width="200" ItemsSource="{Binding AvailableEffects}"
                      SelectedIndex="{Binding SelectedEffectIndex, Mode=TwoWay}" />
            <Button Content="Add" Width="64" Margin="8,0,0,0" Command="{Binding AddEffectCommand}" />
        </StackPanel>

        <TextBlock Grid.Row="5" Text="Effect chain (top → bottom = signal order)"
                   FontWeight="Bold" Margin="0,4" />

        <ScrollViewer Grid.Row="6" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Chain}" />
        </ScrollViewer>

        <StackPanel Grid.Row="7" Margin="0,8,0,0">
            <TextBlock Text="Output level" Margin="0,0,0,2" />
            <ProgressBar Height="16" Minimum="0" Maximum="1" Value="{Binding OutputLevel, Mode=OneWay}" />
            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Text="{Binding Status}" />
        </StackPanel>
    </Grid>
</UserControl>
