<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-windows10.0.26100</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Required for the legacy-AsioOut duplex passthrough test, which has to read/write driver buffers via raw IntPtr. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" Version="0.55.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\NAudio.Asio\NAudio.Asio.csproj" />
    <ProjectReference Include="..\..\src\NAudio.Dmo\NAudio.Dmo.csproj" />
    <ProjectReference Include="..\..\src\NAudio.Vst3\NAudio.Vst3.csproj" />
    <ProjectReference Include="..\..\src\NAudio.Wasapi\NAudio.Wasapi.csproj" />
    <ProjectReference Include="..\..\src\NAudio.WinMM\NAudio.WinMM.csproj" />
    <ProjectReference Include="..\..\src\NAudio.Core\NAudio.Core.csproj" />
    <ProjectReference Include="..\..\src\NAudio.SoundFile\NAudio.SoundFile.csproj" />
  </ItemGroup>

</Project>
