<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <RootNamespace>MfStressTest</RootNamespace>
    <AssemblyName>MfStressTest</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>

  <!--
    DELIBERATELY no NAudio.WinMM reference. The point of this harness is to
    exercise Media Foundation in isolation - any AV here is unambiguously MF,
    not the MF + ACM coexistence observed in the ACM-AV investigation.
  -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\NAudio.Core\NAudio.Core.csproj" />
    <ProjectReference Include="..\..\src\NAudio.Wasapi\NAudio.Wasapi.csproj" />
  </ItemGroup>

</Project>
